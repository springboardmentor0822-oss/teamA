# Server
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/civiv

# Auth
JWT_SECRET=replace_with_a_strong_random_secret

# Email (use Gmail App Password, not your normal Gmail password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# OTP behavior
# true  -> print OTP in server logs (dev only)
# false -> send OTP via email (recommended)
OTP_DEV_MODE=false
